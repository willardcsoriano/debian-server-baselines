# General-purpose .gitignore
# Covers OS artifacts, editors/IDEs, AI coding agents, secrets, logs, and
# common build/temp patterns. Instruction files intentionally committed
# (CLAUDE.md, AGENTS.md, .cursorrules, etc.) are NOT listed here.


# ── Operating systems ─────────────────────────────────────────────────────────

# macOS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*
.nfs*


# ── Editors and IDEs ──────────────────────────────────────────────────────────

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.code-workspace

# JetBrains (IntelliJ, PyCharm, GoLand, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.nvimlog

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*
.org-id-locations
*_archive
.cache

# Sublime Text
*.sublime-workspace
*.sublime-project

# TextMate
*.tmproj
*.tmproject
.tmtags

# Helix
.helix/


# ── AI coding agents ──────────────────────────────────────────────────────────

# Claude Code (Anthropic)
.claude/

# Cursor
.cursor/
.cursorignore
.cursorindexingignore

# Windsurf (Codeium)
.windsurf/

# Codeium
.codeium/

# Aider
.aider
.aider.chat.history.md
.aider.input.history
.aider.tags.cache.v*/

# Continue.dev
.continue/

# Tabnine
.tabnine/

# Amazon Q / CodeWhisperer
.amazonq/
.aws/codewhisperer/

# Sourcegraph Cody
.cody/

# GitHub Copilot (local session state only)
.github/copilot-chat-history/

# Devin
.devin/

# Supermaven
.supermaven/

# Tabby
.tabby/

# OpenAI Codex / ChatGPT CLI
.codex/
.openai/

# Google Gemini CLI
.gemini/

# Kite (discontinued)
.kite/


# ── Secrets and environment ───────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
id_rsa
id_ed25519
id_ecdsa
id_dsa
*.pub
.netrc
.npmrc
.pypirc


# ── Logs and diagnostics ─────────────────────────────────────────────────────
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ── Temp, backup, and patch files ────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.bak.*
*.orig
*.rej
*.patch
*.diff
*.swn


# ── Archives ──────────────────────────────────────────────────────────────────
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.tar.xz
*.zip
*.gz
*.bz2
*.xz
*.7z
*.rar
*.iso


# ── Build and dependency artifacts ───────────────────────────────────────────

# Node / JS
node_modules/
.npm/
.yarn/
.pnp.*
dist/
build/
.next/
.nuxt/
.svelte-kit/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.pytest_cache/
*.egg-info/
dist/
.mypy_cache/
.ruff_cache/

# Go
vendor/

# Rust
target/

# Java / Kotlin / Gradle / Maven
*.class
*.jar
*.war
*.ear
.gradle/
build/
target/

# Ruby
.bundle/
vendor/bundle/

# Generic compiled output
*.o
*.a
*.so
*.dylib
*.exe
*.out
